PORT=3000
UPLOAD_DIR=uploads
DATA_FILE=data/dev-store.json
LLM_PROVIDER=mock
HUNYUAN_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ASR_PROVIDER=mock
STREAMING_ASR_PROVIDER=mock
VOICE_PROVIDER=mock
STREAMING_TTS_PROVIDER=mock

# VOICE_PROVIDER 未来用于 AI 回答朗读 / 声音克隆。
# 真实 TTS 或声音克隆密钥也只能放后端，不能放小程序代码。

# ASR_PROVIDER=tencent 时使用。密钥只允许放后端环境变量，不能放小程序代码。
TENCENT_ASR_SECRET_ID=
TENCENT_ASR_SECRET_KEY=
TENCENT_ASR_APP_ID=
TENCENT_ASR_REGION=ap-guangzhou
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh_large
TENCENT_ASR_DIALECT=auto

# ASR_PROVIDER=aliyun 时使用。
ALIYUN_ASR_ACCESS_KEY_ID=
ALIYUN_ASR_ACCESS_KEY_SECRET=
ALIYUN_ASR_APP_KEY=

# 流式语音对话 WebSocket。开发环境可以使用 ws://localhost:3000。
REALTIME_WS_PATH=/realtime/conversations
