PORT=3000
UPLOAD_DIR=uploads
DATA_FILE=data/dev-store.json

# 数据存储。
# 不设 DATABASE_URL：使用本地 JSON 文件（DATA_FILE），适合最快起步，但重启可能丢数据。
# 设 DATABASE_URL：走 Prisma。默认 schema 为 SQLite（重启不丢，单机演示足够）：
#   DATABASE_URL="file:./dev.db"
#   首次：npm run prisma:migrate:dev  然后 npm run db:seed
# 切 PostgreSQL（生产/多实例）：把 prisma/schema.prisma 的 provider 改为 postgresql，
#   DATABASE_URL="postgresql://memory:memory@localhost:5432/memory"（见 docker-compose.yml），
#   再重新 prisma migrate。
# DATABASE_URL=
LLM_PROVIDER=mock
HUNYUAN_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ASR_PROVIDER=mock
STREAMING_ASR_PROVIDER=mock
VOICE_PROVIDER=mock
STREAMING_TTS_PROVIDER=mock

# VOICE_PROVIDER 未来用于 AI 回答朗读 / 声音克隆。
# 真实 TTS 或声音克隆密钥也只能放后端，不能放小程序代码。

# ASR_PROVIDER=tencent 时使用。密钥只允许放后端环境变量，不能放小程序代码。
TENCENT_ASR_SECRET_ID=
TENCENT_ASR_SECRET_KEY=
TENCENT_ASR_APP_ID=
TENCENT_ASR_REGION=ap-guangzhou
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh_large
TENCENT_ASR_DIALECT=auto

# ASR_PROVIDER=aliyun 时使用。
ALIYUN_ASR_ACCESS_KEY_ID=
ALIYUN_ASR_ACCESS_KEY_SECRET=
ALIYUN_ASR_APP_KEY=

# 流式语音对话 WebSocket。开发环境可以使用 ws://localhost:3000。
REALTIME_WS_PATH=/realtime/conversations

# TTS（语音合成）。VOICE_PROVIDER / STREAMING_TTS_PROVIDER=tencent 时使用。
# 默认复用上面的 TENCENT_ASR_SECRET_ID / KEY，也可单独配置。
TENCENT_TTS_SECRET_ID=
TENCENT_TTS_SECRET_KEY=
TENCENT_TTS_REGION=ap-guangzhou
TENCENT_TTS_VOICE_TYPE=101016

# 文件存储。local=容器磁盘并通过 /files 暴露；cos=腾讯云对象存储（Phase C 实现）。
STORAGE_PROVIDER=local
STORAGE_DIR=storage
STORAGE_PUBLIC_PATH=/files

# 上传大小限制（字节）。
MAX_AUDIO_BYTES=26214400
MAX_IMAGE_BYTES=10485760

# 鉴权。配置后小程序用 wx.login 的 code 走 code2Session 换 openid。
WECHAT_APPID=
WECHAT_SECRET=
JWT_SECRET=dev-insecure-secret-change-me
# Production must set a long random JWT_SECRET and real WeChat credentials.
# DEV_AUTH_BYPASS：不设时，非生产默认开启（离线/演示免登录，req.userId=user_demo_001）。
# 生产请设 NODE_ENV=production，并确保 DEV_AUTH_BYPASS=false。
# DEV_AUTH_BYPASS=false
