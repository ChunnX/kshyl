.record {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.record-stage {
  margin: 56rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.record-circle {
  width: 380rpx;
  height: 380rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 10rpx solid #7dd3fc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: #082f49;
  box-shadow: 0 22rpx 44rpx rgba(12, 74, 110, 0.12);
}

.record-circle.recording {
  border-color: #22c55e;
  background: #ecfdf5;
}

.record-icon {
  width: 82rpx;
  height: 82rpx;
  padding: 20rpx;
  border-radius: 50%;
  background: #0369a1;
  box-sizing: border-box;
}

.record-circle.recording .record-icon {
  background: #15803d;
}

.wave-row {
  height: 92rpx;
  margin-top: 42rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.wave {
  width: 20rpx;
  border-radius: 999rpx;
  background: #bae6fd;
}

.wave-1,
.wave-5 {
  height: 32rpx;
}

.wave-2,
.wave-4 {
  height: 58rpx;
}

.wave-3 {
  height: 84rpx;
}

.wave-row.active .wave {
  background: #22c55e;
}

.record-tip {
  margin-top: 10rpx;
  min-height: 48rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #315f74;
}

.danger-button {
  background: #15803d;
  box-shadow: 0 18rpx 32rpx rgba(21, 128, 61, 0.22);
}
