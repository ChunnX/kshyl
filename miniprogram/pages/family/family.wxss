.form-card,
.person-card {
  margin-top: 36rpx;
  padding: 36rpx;
  background: var(--card-bg);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  transition: var(--transition-smooth);
  box-sizing: border-box;
}

.form-card:hover,
.person-card:hover {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
}

.input-label {
  margin-top: 24rpx;
  margin-bottom: 14rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-dark);
}

.input {
  width: 100%;
  box-sizing: border-box;
  min-height: 96rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-sm);
  border: 3rpx solid #e7e5e4;
  background: #fafaf9;
  font-size: 32rpx;
  color: var(--text-dark);
  transition: var(--transition-smooth);
}

/* 💻 聚焦高亮微动效 */
.input:focus {
  border-color: var(--primary);
  background: #ffffff;
  box-shadow: 0 0 12rpx rgba(217, 119, 6, 0.1);
}

.form-action {
  margin-top: 36rpx;
}

.person-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.person-name {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-dark);
}

.person-relation {
  margin-top: 10rpx;
  font-size: 30rpx;
  color: var(--text-muted);
}
