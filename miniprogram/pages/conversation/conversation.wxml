<view class="page page-soft conversation safe-bottom">
  <view>
    <view class="eyebrow">语音记事与陪聊</view>
    <view class="title">留存声音的温度</view>
    <view class="subtitle">可选择“对话模式”与 AI 暖心互动整理生平，或选择“倾诉模式”进行无打扰单向录音，多角度珍藏家庭记忆。</view>
  </view>

  <view class="mode-switch">
    <view class="mode-option {{mode === 'dialogue' ? 'active' : ''}}" bindtap="setDialogueMode">
      <view class="mode-title">对话模式</view>
      <view class="mode-desc">适合整理生平和故事</view>
    </view>
    <view class="mode-option {{mode === 'vent' ? 'active' : ''}}" bindtap="setVentMode">
      <view class="mode-title">倾诉模式</view>
      <view class="mode-desc">适合先说心里话</view>
    </view>
  </view>

  <view class="dialect-row">
    <view class="dialect-pill {{dialect === 'auto' ? 'active' : ''}}" bindtap="setDialectAuto">自动识别方言</view>
    <view class="dialect-pill {{dialect === 'yue' ? 'active' : ''}}" bindtap="setDialectYue">粤语</view>
    <view class="dialect-pill {{dialect === 'sichuan' ? 'active' : ''}}" bindtap="setDialectSichuan">四川话</view>
  </view>

  <view class="realtime-status">
    <view class="status-dot {{isRecording ? 'listening' : ''}}"></view>
    <view class="status-copy">{{statusText}}</view>
  </view>

  <view wx:if="{{realtimeErrorText}}" class="connection-help">
    <view class="connection-help-title">实时连接没有建立</view>
    <view class="connection-help-text">{{realtimeErrorText}}</view>
    <view class="connection-help-text">请确认后端正在运行，手机和电脑在同一 Wi-Fi，或切换到 wss 隧道/云端地址。</view>
  </view>

  <view wx:if="{{liveTranscript}}" class="live-panel">
    <view class="live-label">实时识别</view>
    <view class="live-text">{{liveTranscript}}</view>
  </view>

  <scroll-view class="message-list" scroll-y>
    <view wx:if="{{messages.length === 0}}" class="empty-message">
      <view class="message-label">等待连接</view>
      <view class="message-bubble">
        <view class="message-text">连接成功后，AI 的第一句提示会显示在这里。</view>
      </view>
    </view>
    <view wx:for="{{messages}}" wx:key="id" class="message {{item.role}}">
      <view class="message-label">{{item.role === 'assistant' ? 'AI' : '我'}}</view>
      <view class="message-bubble">
        <view class="message-text">{{item.text}}</view>
        <view wx:if="{{item.nextQuestion}}" class="next-question">{{item.nextQuestion}}</view>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{photoIds.length}}" class="photo-note">
    已加入 {{photoIds.length}} 张照片，这一轮会一起记下。
  </view>

  <view class="conversation-actions">
    <button class="secondary-button" bindtap="addPhoto">
      <image class="button-icon dark-icon" src="/assets/icons/photo.svg" mode="aspectFit" />
      加入照片
    </button>
    <button wx:if="{{!isRecording}}" class="primary-button" bindtap="startRecord">
      <image class="button-icon" src="/assets/icons/mic-white.svg" mode="aspectFit" />
      按下开始说
    </button>
    <button wx:else class="primary-button finish-button" bindtap="stopRecord">
      <image class="button-icon" src="/assets/icons/stop-white.svg" mode="aspectFit" />
      我说完了
    </button>
  </view>
</view>
