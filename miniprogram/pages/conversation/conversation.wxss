.conversation {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
}

.mode-switch {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.mode-option {
  min-height: 132rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 3rpx solid #bae6fd;
  box-sizing: border-box;
}

.mode-option.active {
  border-color: #0369a1;
  background: #e0f2fe;
}

.mode-title {
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #082f49;
}

.mode-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: #315f74;
}

.dialect-row {
  margin-top: 20rpx;
  display: flex;
  gap: 14rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.dialect-pill {
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #bae6fd;
  display: flex;
  align-items: center;
  color: #075985;
  font-size: 28rpx;
  font-weight: 800;
  flex: 0 0 auto;
}

.dialect-pill.active {
  background: #0369a1;
  color: #ffffff;
  border-color: #0369a1;
}

.realtime-status {
  margin-top: 20rpx;
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border: 2rpx solid #bae6fd;
}

.connection-help {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #fff7ed;
  border: 2rpx solid #fed7aa;
}

.connection-help-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #9a3412;
}

.connection-help-text {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.45;
  color: #7c2d12;
  word-break: break-all;
}

.status-copy {
  font-size: 28rpx;
  font-weight: 800;
  color: #315f74;
}

.status-dot.listening {
  background: #22c55e;
}

.live-panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #ecfdf5;
  border: 2rpx solid #86efac;
}

.live-label {
  font-size: 26rpx;
  font-weight: 800;
  color: #166534;
}

.live-text {
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1.58;
  color: #123f55;
}

.message-list {
  min-height: 360rpx;
  max-height: 520rpx;
  flex: 1 1 auto;
  margin-top: 26rpx;
  padding: 4rpx 0;
  box-sizing: border-box;
}

.message {
  margin-top: 22rpx;
}

.empty-message {
  margin-top: 22rpx;
}

.message-label {
  margin-bottom: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #315f74;
}

.message.user .message-label {
  text-align: right;
}

.message-bubble {
  max-width: 92%;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid #bae6fd;
  box-shadow: 0 12rpx 24rpx rgba(12, 74, 110, 0.08);
  box-sizing: border-box;
}

.message.user .message-bubble {
  margin-left: auto;
  background: #ecfdf5;
  border-color: #86efac;
}

.message-text {
  font-size: 32rpx;
  line-height: 1.62;
  color: #123f55;
}

.next-question {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid #bae6fd;
  font-size: 34rpx;
  line-height: 1.58;
  font-weight: 800;
  color: #075985;
}

.photo-note {
  margin-top: 16rpx;
  min-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #fef3c7;
  color: #854d0e;
  font-size: 28rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
}

.conversation-actions {
  position: fixed;
  left: 36rpx;
  right: 36rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 20;
  margin-top: 0;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  border-radius: 28rpx;
  background: rgba(250, 250, 250, 0.96);
  border: 2rpx solid rgba(186, 230, 253, 0.8);
  box-shadow: 0 20rpx 48rpx rgba(12, 74, 110, 0.14);
  box-sizing: border-box;
}

.conversation-actions .primary-button,
.conversation-actions .secondary-button {
  min-height: 92rpx;
  border-radius: 22rpx;
  font-size: 31rpx;
}

.finish-button {
  background: #15803d;
}

.dark-icon {
  background: #e0f2fe;
  border-radius: 50%;
}
