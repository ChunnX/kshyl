<view class="page page-soft safe-bottom">
  <view class="eyebrow">整理成册</view>
  <view class="title">把家庭记忆整理成一本书</view>
  <view class="subtitle">可以是长辈回忆录，也可以是孩子成长册，先由家人预览校对。</view>

  <image class="hero-image book-image" src="/assets/illustrations/book-preview.svg" mode="aspectFit" />

  <view class="panel">
    <view class="section-title">当前书稿</view>
    <view class="book-result">{{result}}</view>

    <view class="book-outline" wx:if="{{outline.length}}">
      <view class="outline-item" wx:for="{{outline}}" wx:key="chapter">
        <text class="outline-chapter">第{{item.chapter}}章</text>
        <text class="outline-title">{{item.title}}</text>
      </view>
    </view>
  </view>

  <button class="primary-button action" bindtap="exportBook" loading="{{generating}}" disabled="{{generating}}">
    <image class="button-icon" src="/assets/icons/book-white.svg" mode="aspectFit" />
    {{generating ? '正在生成...' : '生成书稿'}}
  </button>

  <button class="primary-button action" bindtap="downloadBook" wx:if="{{downloadUrl}}">
    下载 Word 文档
  </button>
</view>
