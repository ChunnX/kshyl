page {
  min-height: 100%;
  background: #fffbf2; /* 💻 极具质感的温润暖米白/纸张色背景，完美契合小程序头像背景 */
  color: #2c1b18; /* 💻 温暖的深可可褐色，代替死板的冷石板色，护眼且温馨 */
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Helvetica, Arial, sans-serif;
  
  /* 🎨 小程序头像专属品牌色系（Warm Sunset Orange & Deep Teal & Coral Heart） */
  --primary: #f25c22; /* 活力落日橙，主色 */
  --primary-gradient: linear-gradient(135deg, #ffa853, #f25c22);
  --primary-light: #ffefe6;
  
  --secondary: #1e6b7b; /* 优雅深青绿（托起一切的书本色），辅色 */
  --secondary-gradient: linear-gradient(135deg, #2ca0ac, #145a65);
  --secondary-light: #e6f4f6;
  
  --accent-gold: #e83c3c; /* 温暖爱心红，强调色 */
  --accent-gold-gradient: linear-gradient(135deg, #ff7575, #e83c3c);
  
  /* 🎨 辅助背景字色 */
  --bg-soft: #faf2dc; /* 优雅香草奶黄色 */
  --card-bg: #ffffff;
  --border-color: #f5ecd5; /* 暖米色边框线 */
  --text-dark: #2c1b18;
  --text-muted: #7a6661; /* 暖泥灰色 */
  
  /* 📦 拟物化轻量级投影 */
  --shadow-sm: 0 4rpx 16rpx rgba(242, 92, 34, 0.03);
  --shadow-md: 0 16rpx 48rpx rgba(242, 92, 34, 0.05);
  --shadow-lg: 0 24rpx 64rpx rgba(242, 92, 34, 0.08);
  
  /* 📦 圆角系统 */
  --radius-sm: 16rpx;
  --radius-md: 28rpx;
  --radius-lg: 40rpx;
  --radius-pill: 999rpx;
  
  /* 📦 阻尼物理过渡 */
  --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 44rpx 36rpx 64rpx;
  opacity: 1;
}

.page-soft {
  background: #fafafa;
}

/* 🏷️ 圆角缎带标签 */
.eyebrow {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-pill);
  background: var(--primary-light);
  color: #0369a1;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

/* 📝 经典排版标题 */
.title {
  margin-top: 24rpx;
  font-size: 54rpx;
  line-height: 1.25;
  font-weight: 800;
  color: var(--text-dark);
  letter-spacing: -0.5rpx;
}

.subtitle {
  margin-top: 20rpx;
  font-size: 32rpx;
  line-height: 1.68;
  color: var(--text-muted);
}

.hero-image {
  width: 100%;
  height: 420rpx;
  margin-top: 40rpx;
  border-radius: var(--radius-md);
  display: block;
}

/* 🚀 物理质感渐变按钮 */
.primary-button,
.secondary-button,
.quiet-button {
  width: 100% !important;
  min-height: 112rpx;
  border-radius: var(--radius-md);
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin: 0;
  transition: var(--transition-smooth);
}

/* 🔘 物理触感反馈 */
.primary-button:active,
.secondary-button:active,
.quiet-button:active {
  transform: scale(0.975);
  opacity: 0.92;
}

.primary-button::after,
.secondary-button::after,
.quiet-button::after {
  border: 0;
}

.primary-button {
  background: var(--primary-gradient);
  color: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(2, 132, 199, 0.2);
}

.secondary-button {
  background: #ffffff;
  color: var(--text-dark);
  border: 3rpx solid #e2e8f0;
  box-shadow: var(--shadow-sm);
}

.quiet-button {
  background: var(--secondary-light);
  color: #15803d;
}

.button-icon {
  width: 42rpx;
  height: 42rpx;
  margin-right: 18rpx;
}

/* 📦 拟物白瓷卡片 */
.panel,
.form-card {
  margin-top: 36rpx;
  padding: 36rpx;
  background: var(--card-bg);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--border-color);
  box-shadow: var(--shadow-md);
  box-sizing: border-box;
  transition: var(--transition-smooth);
}

.form-card:hover,
.panel:hover {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
}

.notice-panel {
  background: var(--secondary-light);
  border-color: #bbf7d0;
}

.large-text {
  font-size: 34rpx;
  line-height: 1.68;
  color: var(--text-dark);
}

.quiet-text {
  font-size: 30rpx;
  line-height: 1.64;
  color: var(--text-muted);
}

.section-title {
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 800;
  color: var(--text-dark);
  border-left: 8rpx solid var(--primary);
  padding-left: 20rpx;
  margin-bottom: 24rpx;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--secondary);
  flex: 0 0 auto;
}

.tag {
  display: inline-flex;
  min-height: 46rpx;
  padding: 0 20rpx;
  align-items: center;
  border-radius: var(--radius-pill);
  background: var(--secondary-light);
  color: #15803d;
  font-size: 26rpx;
  font-weight: 700;
}

.actions {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
